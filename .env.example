# Copy to .env and fill in. NEVER commit .env.
# ───────────────────────────────────────────────────────────────────────

# Required — Google Gemini API key.
# Get one (free) from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-key-here

# ── Models (optional overrides; sensible defaults in rag/config.py) ─────
# LLM_MODEL=gemini-2.5-flash
# EMBEDDING_MODEL=models/gemini-embedding-001

# ── Qdrant (optional; defaults to local docker-compose service) ─────────
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# ── Retrieval tuning (optional) ─────────────────────────────────────────
# RETRIEVAL_TOP_K=4
# RERANK_TOP_N=4
# RERANKER_MODEL=BAAI/bge-reranker-base

# ── Observability (optional) — LangSmith tracing ────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-key
# LANGCHAIN_PROJECT=pdf-rag
